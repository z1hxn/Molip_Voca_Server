PORT=4000

# Single frontend origin
FRONTEND_ORIGIN=http://localhost:5173

# Multiple frontend origins (comma separated). If set, this takes precedence over FRONTEND_ORIGIN.
# Example:
# FRONTEND_ORIGINS=https://your-frontend.onrender.com,https://preview-frontend.onrender.com

# Auth cookie config (cross-subdomain production example)
AUTH_COOKIE_NAME=molip_token
AUTH_COOKIE_DOMAIN=.molip.kro.kr
AUTH_COOKIE_MAX_AGE_MS=604800000

# In production use true (required for SameSite=None)
AUTH_COOKIE_SECURE=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Required in production to read public/unlisted data regardless of requester RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
